<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Nidhi — Quiz</title>
  <style>
    :root{
      --bg1:#ff4d6d; --bg2:#845ec2;
      --card:#ffffff; --text:#1f1f1f;
      --muted:#6b6b6b; --good:#16a34a; --bad:#dc2626;
    }
    *{box-sizing:border-box}
    body{
      margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:
        radial-gradient(1200px 800px at 20% 20%, #ffd6e0 0%, transparent 55%),
        radial-gradient(1000px 700px at 85% 30%, #e0d4ff 0%, transparent 55%),
        linear-gradient(135deg, var(--bg1), var(--bg2));
      padding:18px;
      color:var(--text);
    }
    .wrap{
      width:min(860px, 100%);
      background: rgba(255,255,255,0.14);
      border:1px solid rgba(255,255,255,0.25);
      border-radius:22px;
      padding:18px;
      backdrop-filter: blur(10px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.18);
    }
    header{
      display:flex; gap:10px; flex-wrap:wrap;
      align-items:baseline; justify-content:space-between;
      padding: 8px 8px 14px;
      color:white;
    }
    h1{margin:0; font-size:22px; letter-spacing:.2px}
    .sub{margin:0; font-size:13px; color: rgba(255,255,255,0.9)}
    .card{
      background:var(--card);
      border-radius:18px;
      padding:18px;
      box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }
    .progress{
      display:flex; align-items:center; gap:10px; margin-bottom:12px;
      font-size:13px; color:#444;
    }
    .bar{
      flex:1; height:10px; border-radius:999px; background:#f1f1f1; overflow:hidden;
      border:1px solid #eee;
    }
    .bar > i{
      display:block; height:100%; width:0%;
      background: linear-gradient(90deg, #ff4d6d, #ffb703);
      border-radius:999px;
      transition: width .25s ease;
    }
    .q{
      font-size:18px;
      line-height:1.35;
      margin: 6px 0 10px;
    }
    .hint{
      margin: 0 0 12px;
      font-size:13px;
      color: var(--muted);
    }

    /* Multiple choice */
    .options{
      display:grid;
      gap:10px;
    }
    .opt{
      border:1px solid #e7e7e7;
      border-radius:14px;
      padding:12px 12px;
      display:flex; gap:10px; align-items:flex-start;
      cursor:pointer;
      transition: transform .05s ease, border-color .2s ease, box-shadow .2s ease;
      user-select:none;
    }
    .opt:hover{ border-color:#ff8fab; box-shadow: 0 8px 18px rgba(0,0,0,0.06); }
    .opt:active{ transform: translateY(1px); }
    .badge{
      width:28px; height:28px; border-radius:10px;
      display:flex; align-items:center; justify-content:center;
      background:#f6f6f8;
      font-weight:800;
    }
    .opt.selected{
      border-color:#ff4d6d;
      box-shadow: 0 0 0 4px rgba(255,77,109,0.14);
    }

    /* Final slide: 3 text questions */
    .grid3{ display:grid; gap:12px; }
    .field{
      border:1px solid #e7e7e7;
      border-radius:14px;
      padding:12px;
    }
    .field label{
      display:block;
      font-weight:750;
      margin-bottom:6px;
      font-size:14px;
    }
    .field .mini{
      font-size:12px; color:var(--muted); margin-bottom:8px;
    }
    input[type="text"]{
      width:100%;
      font-size:16px;
      padding:12px 12px;
      border-radius:12px;
      border:1px solid #ddd;
      outline:none;
    }
    input[type="text"]:focus{
      border-color:#ff4d6d;
      box-shadow: 0 0 0 4px rgba(255,77,109,0.15);
    }

    .row{
      display:flex; gap:10px; flex-wrap:wrap;
      margin-top: 14px;
    }
    button{
      border:0; cursor:pointer;
      border-radius:12px;
      padding:12px 14px;
      font-size:15px;
      font-weight:700;
      transition: transform .05s ease, filter .2s ease;
    }
    button:active{ transform: translateY(1px); }
    .primary{
      background: linear-gradient(135deg, #ff4d6d, #ff8fab);
      color:white;
      flex:1;
      min-width:170px;
    }
    .ghost{
      background:#f6f6f8;
      color:#333;
      min-width:140px;
    }
    .msg{
      margin-top:10px;
      font-size:13px;
      min-height:18px;
      color: var(--bad);
    }
    .ok{ color: var(--good); }

    /* Popup */
    .overlay{
      position:fixed; inset:0;
      background: rgba(0,0,0,0.52);
      display:none;
      align-items:center; justify-content:center;
      padding:18px;
      z-index:50;
    }
    .overlay.show{ display:flex; }
    .popup{
      width:min(740px, 100%);
      background:white;
      border-radius:22px;
      padding:22px;
      text-align:center;
      box-shadow: 0 18px 70px rgba(0,0,0,0.35);
      position:relative;
      overflow:hidden;
    }
    .close{
      position:absolute; top:10px; right:10px;
      width:42px; height:42px; border-radius:999px;
      background:#f2f2f2;
      display:flex; align-items:center; justify-content:center;
      font-size:18px;
      cursor:pointer;
      border:0;
    }
    .popTitle{
      margin: 4px 0 6px;
      font-size:30px;
      letter-spacing:.2px;
    }
    .popSub{
      margin: 0 0 14px;
      font-size:16px;
      color:#333;
      line-height:1.35;
    }
    .yesBox{
      display:inline-flex; align-items:center; justify-content:center; gap:10px;
      padding: 12px 18px;
      border-radius:999px;
      background: linear-gradient(135deg, #ff4d6d, #845ec2);
      color:white;
      font-weight:900;
      font-size:18px;
    }
    .hearts{ position:absolute; inset:0; pointer-events:none; overflow:hidden; }
    .heart{
      position:absolute;
      font-size:18px;
      opacity:.9;
      animation: fall linear forwards;
      filter: drop-shadow(0 6px 8px rgba(0,0,0,0.15));
    }
    @keyframes fall{
      from{ transform: translateY(-30px) rotate(0deg); }
      to{ transform: translateY(120vh) rotate(360deg); }
    }
    .tiny{ font-size:12px; color:#666; margin-top:12px; }
  </style>
</head>
<body>
  <div class="wrap">
    <header>
      <div>
        <h1>Nidhi — Quick Quiz</h1>
        <p class="sub">Pick the right options 😭</p>
      </div>
      <p class="sub" id="stepLabel">For Nidhi 💞</p>
    </header>

    <div class="card">
      <div class="progress">
        <span id="count">1/7</span>
        <div class="bar"><i id="fill"></i></div>
      </div>

      <div class="q" id="question"></div>
      <p class="hint" id="hint"></p>

      <!-- MCQ -->
      <div id="mcq" class="options" aria-live="polite"></div>

      <!-- Final slide: 3 text questions -->
      <div id="finalSlide" style="display:none;">
        <div class="grid3">
          <div class="field">
            <label>What’s “why” in one letter?</label>
            <div class="mini">Hint: Y</div>
            <input id="t1" type="text" maxlength="3" placeholder="Type here..." />
          </div>
          <div class="field">
            <label>What’s 4 - 1?</label>
            <div class="mini">Hint: 3</div>
            <input id="t2" type="text" maxlength="3" placeholder="Type here..." />
          </div>
          <div class="field">
            <label>What are you missing the most? _ EX</label>
            <div class="mini">Hint: S</div>
            <input id="t3" type="text" maxlength="3" placeholder="Type here..." />
          </div>
        </div>
        <div class="tiny">Type the answers exactly as the hints 😉</div>
      </div>

      <div class="row">
        <button class="ghost" id="back">Back</button>
        <button class="primary" id="next">Next</button>
      </div>

      <div class="msg" id="msg"></div>
    </div>
  </div>

  <!-- Popup -->
  <div class="overlay" id="overlay" aria-hidden="true">
    <div class="popup" role="dialog" aria-modal="true" aria-label="YES popup">
      <button class="close" id="close" title="Close">✕</button>
      <div class="hearts" id="hearts"></div>
      <h2 class="popTitle">YES ✅</h2>
      <p class="popSub">Now you have to say yes to everything I say, Nidhi.</p>
      <div class="yesBox">YES</div>
      <p class="tiny">Screenshot this 😭</p>
    </div>
  </div>

  <script>
    // 6 MCQ + 1 final slide with 3 typed answers
    const steps = [
      {
        type: "mcq",
        q: "Where did we first meet?",
        options: [
          { key:"A", text:"Scape Victoria" },
          { key:"B", text:"Scape La Trobe" },
          { key:"C", text:"My bed" },
          { key:"D", text:"In my dreams (I had déjà vu of you long time back)" }
        ],
        correct: "D"
      },
      {
        type: "mcq",
        q: "What is my biggest red flag?",
        options: [
          { key:"A", text:"I lie" },
          { key:"B", text:"I lie because I lie" },
          { key:"C", text:"I lie because I like to lie" },
          { key:"D", text:"I lie because I don’t want to lie but it just happens" }
        ],
        correct: "A"
      },
      {
        type: "mcq",
        q: "What do I bring to the table?",
        options: [
          { key:"A", text:"Love" },
          { key:"B", text:"Lust" },
          { key:"C", text:"Myself" },
          { key:"D", text:"A broke friend" }
        ],
        correct: "D"
      },
      {
        type: "mcq",
        q: "What’s my biggest talent?",
        options: [
          { key:"A", text:"To love you" },
          { key:"B", text:"To lie" },
          { key:"C", text:"I’m just smart in everything yet dyslexic" },
          { key:"D", text:"All of the above" }
        ],
        correct: "D"
      },
      {
        type: "mcq",
        q: "What is my love language?",
        options: [
          { key:"A", text:"To hit you" },
          { key:"B", text:"To touch you" },
          { key:"C", text:"To get silent" },
          { key:"D", text:"All of them because why not" }
        ],
        correct: "D"
      },
      {
        type: "mcq",
        q: "Why do you not love me?",
        options: [
          { key:"A", text:"Because you just can’t" },
          { key:"B", text:"Because you don’t want to" },
          { key:"C", text:"Because I’m not good enough" },
          { key:"D", text:"Because if you love me then you won’t be able to love anyone else (mom, dad, anyone)… and then I’ll punch you for loving me so much" }
        ],
        correct: "D"
      },
      {
        type: "final",
        q: "Final slide 😭 (Type the answers)",
        hint: "Use the hints exactly 😉",
        correctText: ["Y", "3", "S"]
      }
    ];

    let idx = 0;
    const answers = [];

    const elQ = document.getElementById("question");
    const elHint = document.getElementById("hint");
    const elMCQ = document.getElementById("mcq");
    const elFinal = document.getElementById("finalSlide");
    const elMsg = document.getElementById("msg");
    const elCount = document.getElementById("count");
    const elFill = document.getElementById("fill");

    const btnNext = document.getElementById("next");
    const btnBack = document.getElementById("back");

    const overlay = document.getElementById("overlay");
    const closeBtn = document.getElementById("close");
    const hearts = document.getElementById("hearts");

    const t1 = document.getElementById("t1");
    const t2 = document.getElementById("t2");
    const t3 = document.getElementById("t3");

    function setProgress() {
      const total = steps.length;
      elCount.textContent = `${idx + 1}/${total}`;
      elFill.style.width = `${((idx + 1) / total) * 100}%`;
    }

    function render() {
      const step = steps[idx];
      setProgress();
      elMsg.textContent = "";
      elMsg.classList.remove("ok");

      elQ.textContent = step.q;
      elHint.textContent = step.hint || "";

      btnBack.disabled = idx === 0;
      btnBack.style.opacity = idx === 0 ? 0.6 : 1;

      btnNext.textContent = (idx === steps.length - 1) ? "Finish" : "Next";

      if (step.type === "mcq") {
        elFinal.style.display = "none";
        elMCQ.style.display = "grid";
        elMCQ.innerHTML = "";

        const saved = answers[idx]; // "A"/"B"/...
        step.options.forEach(opt => {
          const div = document.createElement("div");
          div.className = "opt" + (saved === opt.key ? " selected" : "");
          div.tabIndex = 0;

          div.innerHTML = `
            <div class="badge">${opt.key}</div>
            <div style="font-weight:650">${opt.text}</div>
          `;

          div.addEventListener("click", () => selectOption(opt.key));
          div.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              selectOption(opt.key);
            }
          });

          elMCQ.appendChild(div);
        });
      } else {
        elMCQ.style.display = "none";
        elFinal.style.display = "block";

        const saved = answers[idx] || ["", "", ""];
        t1.value = saved[0] || "";
        t2.value = saved[1] || "";
        t3.value = saved[2] || "";
        t1.focus();
      }
    }

    function selectOption(key) {
      answers[idx] = key;
      [...elMCQ.querySelectorAll(".opt")].forEach(el => el.classList.remove("selected"));
      const selected = [...elMCQ.querySelectorAll(".opt")]
        .find(el => el.querySelector(".badge")?.textContent === key);
      if (selected) selected.classList.add("selected");
    }

    function validate() {
      const step = steps[idx];

      if (step.type === "mcq") {
        const pick = answers[idx];
        if (!pick) {
          elMsg.textContent = "Pick an option first 😭";
          return false;
        }
        if (pick !== step.correct) {
          elMsg.textContent = "Wrong 😌 Try again.";
          return false;
        }
        elMsg.textContent = "Correct ✅";
        elMsg.classList.add("ok");
        return true;
      }

      // final slide validation: must be Y, 3, S
      const a1 = (t1.value || "").trim().toUpperCase();
      const a2 = (t2.value || "").trim().toUpperCase();
      const a3 = (t3.value || "").trim().toUpperCase();
      answers[idx] = [a1, a2, a3];

      if (!a1 || !a2 || !a3) {
        elMsg.textContent = "Fill all three 😭";
        return false;
      }
      if (a1 !== "Y" || a2 !== "3" || a3 !== "S") {
        elMsg.textContent = "Nope 😌 Use the hints exactly.";
        return false;
      }
      elMsg.textContent = "Perfect ✅";
      elMsg.classList.add("ok");
      return true;
    }

    function next() {
      if (!validate()) return;

      if (idx < steps.length - 1) {
        idx++;
        render();
      } else {
        showPopup();
      }
    }

    function back() {
      if (idx > 0) idx--;
      render();
    }

    function showPopup() {
      overlay.classList.add("show");
      overlay.setAttribute("aria-hidden", "false");
      spawnHearts(60);
    }

    function hidePopup() {
      overlay.classList.remove("show");
      overlay.setAttribute("aria-hidden", "true");
      hearts.innerHTML = "";
      idx = 0;
      answers.length = 0;
      render();
    }

    function spawnHearts(n=40) {
      hearts.innerHTML = "";
      const emojis = ["💖","💘","💝","💗","💞","💕"];
      for (let k = 0; k < n; k++) {
        const d = document.createElement("div");
        d.className = "heart";
        d.textContent = emojis[Math.floor(Math.random()*emojis.length)];
        d.style.left = (Math.random() * 100) + "vw";
        d.style.animationDuration = (2.6 + Math.random()*3.2) + "s";
        d.style.fontSize = (14 + Math.random()*20) + "px";
        d.style.opacity = (0.55 + Math.random()*0.45).toFixed(2);
        d.style.animationDelay = (Math.random()*0.6) + "s";
        hearts.appendChild(d);
      }
    }

    btnNext.addEventListener("click", next);
    btnBack.addEventListener("click", back);

    closeBtn.addEventListener("click", hidePopup);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) hidePopup(); });

    [t1,t2,t3].forEach(inp => {
      inp.addEventListener("keydown", (e) => { if (e.key === "Enter") next(); });
    });

    render();
  </script>
</body>
</html>
